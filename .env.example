# ─────────────────────────────────────────────────────────────────────────────
# PDRP — Environment Variables
# Copy to .env and fill in secrets. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://pdrp:pdrp_secret@localhost:5432/pdrp

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=change-me-in-production-please

# Alerting (optional for Sprint 0)
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# OpenLineage
OPENLINEAGE_URL=http://localhost:5000
OPENLINEAGE_NAMESPACE=pdrp
